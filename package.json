{
  "name": "contract-trading-tool",
  "version": "1.0.0",
  "private": true,
  "description": "Static frontend + Node/Express API proxy for contract market dashboard",
  "main": "server.js",
  "type": "commonjs",
  "engines": {
    "node": ">=20 <23"
  },
  "scripts": {
    "start": "node server.js",
    "serve": "http-server . -p 5173",
